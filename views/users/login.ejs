<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5 col-xl-4">
            <div class="ss-auth-card">
                <div class="text-center mb-4">
                    <h3>Welcome back</h3>
                    <p class="ss-auth-subtitle">Log in to manage your bookings and sanctuaries.</p>
                </div>
                <form action="/login" method="POST" novalidate class="needs-validation">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" name="username" id="username"
                            placeholder="Enter your username" required>
                        <div class="invalid-feedback">Please enter your username.</div>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" name="password" id="password"
                            placeholder="Enter your password" required>
                        <div class="invalid-feedback">Please enter your password.</div>
                    </div>
                    <button class="btn btn-success btn-interact w-100 py-2">Log In</button>
                </form>
                <div class="text-center mt-4 border-top pt-3">
                    <span style="font-size: 0.85rem; color: var(--ss-gray);">New to StayScape? <a href="/signup" class="fw-bold" style="color: var(--ss-primary); text-decoration: none;">Create an account</a></span>
                </div>
            </div>
        </div>
    </div>
</div>
