<% layout("/layouts/boilerplate") %>

<section class="ss-hero" data-aos="fade-down">
    <div class="hero-content">
        <h1>Find your next luxury escape</h1>
        <p>Discover handpicked villas, architectural gems, beachfront estates, and cozy cabins curated for the discerning traveler.</p>
        
        <!-- Embedded Premium Search Widget -->
        <div class="ss-hero-search" data-aos="zoom-in" data-aos-delay="200">
            <form class="d-flex ss-search-form w-100" role="search" action="/listings/search" method="get">
                <div class="ss-search-wrapper">
                    <i class="fa-solid fa-magnifying-glass ss-search-icon"></i>
                    <input class="form-control search-inp" type="search"
                        placeholder="Search by destination, country, title..." aria-label="Search" name="q" required />
                </div>
                <button class="btn search-btn btn-interact" type="submit">Search Stays</button>
            </form>
        </div>
    </div>
</section>

<!-- Category Slider Panel -->
<div id="filter-wrapper" data-aos="fade-up" data-aos-delay="100">
    <button class="scroll-btn left-btn" aria-label="Scroll filters left"><i class="fa-solid fa-chevron-left"></i></button>
    <div id="filters-container">
        <div id="filters">
            <div class="filter">
                <a href="/listings/filter/Rooms"><div><i class="fa-solid fa-bed"></i></div><p>Rooms</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Iconic-Cities"><div><i class="fa-solid fa-mountain-city"></i></div><p>Iconic Cities</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Trending"><div><i class="fa-solid fa-fire"></i></div><p>Trending</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Mountains"><div><i class="fa-solid fa-mountain-sun"></i></div><p>Mountains</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Castles"><div><i class="fa-brands fa-fort-awesome"></i></div><p>Castles</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Amazing-Pools"><div><i class="fa-solid fa-person-swimming"></i></div><p>Amazing Pools</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Camping"><div><i class="fa-solid fa-campground"></i></div><p>Camping</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Farm"><div><i class="fa-solid fa-cow"></i></div><p>Farm</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Arctic"><div><i class="fa-solid fa-snowflake"></i></div><p>Arctic</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Beach"><div><i class="fa-solid fa-umbrella-beach"></i></div><p>Beach</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Boat"><div><i class="fa-solid fa-sailboat"></i></div><p>Boat</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Ski-in-out"><div><i class="fa-solid fa-person-snowboarding"></i></div><p>Ski-in/out</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Apartment"><div><i class="fa-solid fa-building"></i></div><p>Apartment</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/New"><div><i class="fa-solid fa-key"></i></div><p>New Stays</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Woodlands"><div><i class="fa-solid fa-tree-city"></i></div><p>Woodlands</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Lake"><div><i class="fa-solid fa-water"></i></div><p>Lake</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Cabins"><div><i class="fa-solid fa-house"></i></div><p>Cabins</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Countryside"><div><i class="fa-solid fa-house-chimney-window"></i></div><p>Countryside</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Bed-and-Breakfasts"><div><i class="fa-solid fa-mug-hot"></i></div><p>Bed & Breakfast</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Campsite"><div><i class="fa-solid fa-tents"></i></div><p>Campsite</p></a>
            </div>
            <div class="filter">
                <a href="/listings/filter/Historical-Homes"><div><i class="fa-solid fa-landmark"></i></div><p>Historical</p></a>
            </div>
        </div>
    </div>
    <button class="scroll-btn right-btn" aria-label="Scroll filters right"><i class="fa-solid fa-chevron-right"></i></button>
    <div class="tax-toggle">
        <div class="toggle-container">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>
</div>

<!-- Modern Listings Grid -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-adjust" data-aos="fade-up" data-aos-delay="200">
    <% for(let i = 0; i < allListings.length; i++) { let listing = allListings[i]; %>
        <div class="col">
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card listing-card">
                    <!-- Image Wrapper with category badge -->
                    <div class="card-img-top-wrapper">
                        <% if(listing.category) { %>
                            <span class="listing-category-badge"><%= listing.category %></span>
                        <% } %>
                        <img src="<%= listing.image.url %>" class="card-img-top listing-index-img" alt="<%= listing.title %>" loading="lazy">
                        <div class="card-img-overlay"></div>
                    </div>
                    <!-- Body info -->
                    <div class="listing-card-body">
                        <p class="listing-card-text">
                            <b><%= listing.title %></b>
                            <span style="font-size: 0.85rem; color: var(--ss-gray); display: flex; align-items: center; gap: 4px; margin-top: 0.25rem;">
                                <i class="fa-solid fa-location-dot" style="font-size: 0.75rem;"></i> <%= listing.location %>, <%= listing.country %>
                            </span>
                        </p>
                        <div class="listing-card-price">
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> <span>/ night</span>
                            <span class="tax-info">&nbsp;&nbsp;&bull;&nbsp;&nbsp;&#8377; <%= (listing.price * 1.18).toLocaleString("en-IN") %> total</span>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</div>
