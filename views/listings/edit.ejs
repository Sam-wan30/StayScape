<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="ss-form-card">
                <form action="/listings/<%= listing._id%>?_method=PUT" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
                    <div class="text-center mb-4">
                        <h3 class="fw-extrabold mb-1" style="letter-spacing: -0.03em;">Edit Your Listing</h3>
                        <p class="text-muted">Update listing details, pricing, categories, or upload a new image.</p>
                    </div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label for="title" class="form-label">Listing Title</label>
                        <input type="text" class="form-control" name="listing[title]" id="title"
                            placeholder="Enter title" required value="<%= listing.title %>">
                        <div class="valid-feedback">Title looks good!</div>
                        <div class="invalid-feedback">Please enter a valid title.</div>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="listing[description]" class="form-control" id="description" cols="30" rows="6"
                            placeholder="Enter description" required><%= listing.description %></textarea>
                        <div class="invalid-feedback">Please write a short description.</div>
                    </div>

                    <!-- Original Image Preview -->
                    <div class="mb-4 text-center">
                        <label class="form-label d-block text-start">Current Cover Image</label>
                        <div class="p-2 border rounded-3 bg-light d-inline-block">
                            <img style="border-radius: var(--ss-radius); max-height: 14rem; object-fit: cover;" src="<%= imageUrl %>" alt="Current Image">
                        </div>
                    </div>

                    <!-- Upload New Image -->
                    <div class="mb-4">
                        <label for="image" class="form-label">Upload New Cover Image (Optional)</label>
                        <input name="listing[image]" type="file" class="form-control" id="image" />
                        <span class="text-muted" style="font-size: 0.8rem;">Leave blank to keep the current image.</span>
                    </div>

                    <!-- Category Select Panel -->
                    <div class="mb-4">
                        <label class="form-label">Listing Category</label>
                        <div class="p-3 bg-light rounded-3 border">
                            <div class="row row-cols-2 row-cols-md-3 g-3">
                                <!-- Rooms -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="rooms" name="listing[category]" value="Rooms" required <%=listing.category==='Rooms' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="rooms">
                                            <i class="fa-solid fa-bed me-1 text-secondary"></i> Rooms
                                        </label>
                                    </div>
                                </div>
                                <!-- Iconic Cities -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="iconic-cities" name="listing[category]" value="Iconic-Cities" required <%=listing.category==='Iconic-Cities' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="iconic-cities">
                                            <i class="fa-solid fa-mountain-city me-1 text-secondary"></i> Cities
                                        </label>
                                    </div>
                                </div>
                                <!-- Mountains -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="mountains" name="listing[category]" value="Mountains" required <%=listing.category==='Mountains' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="mountains">
                                            <i class="fa-solid fa-mountain-sun me-1 text-secondary"></i> Mountains
                                        </label>
                                    </div>
                                </div>
                                <!-- Castles -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="castles" name="listing[category]" value="Castles" required <%=listing.category==='Castles' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="castles">
                                            <i class="fa-brands fa-fort-awesome me-1 text-secondary"></i> Castles
                                        </label>
                                    </div>
                                </div>
                                <!-- Pools -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="amazing-pools" name="listing[category]" value="Amazing-Pools" required <%=listing.category==='Amazing-Pools' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="amazing-pools">
                                            <i class="fa-solid fa-person-swimming me-1 text-secondary"></i> Pools
                                        </label>
                                    </div>
                                </div>
                                <!-- Cabins -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="cabins" name="listing[category]" value="Cabins" required <%=listing.category==='Cabins' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="cabins">
                                            <i class="fa-solid fa-house me-1 text-secondary"></i> Cabins
                                        </label>
                                    </div>
                                </div>
                                <!-- Camping -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="camping" name="listing[category]" value="Camping" required <%=listing.category==='Camping' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="camping">
                                            <i class="fa-solid fa-campground me-1 text-secondary"></i> Camping
                                        </label>
                                    </div>
                                </div>
                                <!-- Farm -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="farm" name="listing[category]" value="Farm" required <%=listing.category==='Farm' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="farm">
                                            <i class="fa-solid fa-cow me-1 text-secondary"></i> Farm
                                        </label>
                                    </div>
                                </div>
                                <!-- Arctic -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="arctic" name="listing[category]" value="Arctic" required <%=listing.category==='Arctic' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="arctic">
                                            <i class="fa-solid fa-snowflake me-1 text-secondary"></i> Arctic
                                        </label>
                                    </div>
                                </div>
                                <!-- Beach -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="beach" name="listing[category]" value="Beach" required <%=listing.category==='Beach' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="beach">
                                            <i class="fa-solid fa-umbrella-beach me-1 text-secondary"></i> Beach
                                        </label>
                                    </div>
                                </div>
                                <!-- Boat -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="boat" name="listing[category]" value="Boat" required <%=listing.category==='Boat' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="boat">
                                            <i class="fa-solid fa-sailboat me-1 text-secondary"></i> Boat
                                        </label>
                                    </div>
                                </div>
                                <!-- Ski-in/out -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="ski-in-out" name="listing[category]" value="Ski-in-out" required <%=listing.category==='Ski-in-out' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="ski-in-out">
                                            <i class="fa-solid fa-person-snowboarding me-1 text-secondary"></i> Ski-in/out
                                        </label>
                                    </div>
                                </div>
                                <!-- Apartment -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="apartment" name="listing[category]" value="Apartment" required <%=listing.category==='Apartment' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="apartment">
                                            <i class="fa-solid fa-building me-1 text-secondary"></i> Apartment
                                        </label>
                                    </div>
                                </div>
                                <!-- New -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="new" name="listing[category]" value="New" required <%=listing.category==='New' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="new">
                                            <i class="fa-solid fa-key me-1 text-secondary"></i> New
                                        </label>
                                    </div>
                                </div>
                                <!-- Woodlands -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="woodlands" name="listing[category]" value="Woodlands" required <%=listing.category==='Woodlands' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="woodlands">
                                            <i class="fa-solid fa-tree-city me-1 text-secondary"></i> Woodlands
                                        </label>
                                    </div>
                                </div>
                                <!-- Lake -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="lake" name="listing[category]" value="Lake" required <%=listing.category==='Lake' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="lake">
                                            <i class="fa-solid fa-water me-1 text-secondary"></i> Lake
                                        </label>
                                    </div>
                                </div>
                                <!-- Countryside -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="countryside" name="listing[category]" value="Countryside" required <%=listing.category==='Countryside' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="countryside">
                                            <i class="fa-solid fa-house-chimney-window me-1 text-secondary"></i> Countryside
                                        </label>
                                    </div>
                                </div>
                                <!-- Bed & Breakfast -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="bed-and-breakfasts" name="listing[category]" value="Bed-and-Breakfasts" required <%=listing.category==='Bed-and-Breakfasts' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="bed-and-breakfasts">
                                            <i class="fa-solid fa-mug-hot me-1 text-secondary"></i> Bed & Bkfst
                                        </label>
                                    </div>
                                </div>
                                <!-- Campsite -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="campsite" name="listing[category]" value="Campsite" required <%=listing.category==='Campsite' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="campsite">
                                            <i class="fa-solid fa-tents me-1 text-secondary"></i> Campsite
                                        </label>
                                    </div>
                                </div>
                                <!-- Historical Homes -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="historical-homes" name="listing[category]" value="Historical-Homes" required <%=listing.category==='Historical-Homes' ? 'checked' : '' %>>
                                        <label class="form-check-label" for="historical-homes">
                                            <i class="fa-solid fa-landmark me-1 text-secondary"></i> Historical
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="invalid-feedback mt-2">Please select a category for your property.</div>
                    </div>

                    <!-- Price, Location, Country Row -->
                    <div class="row g-3">
                        <div class="mb-4 col-md-4">
                            <label for="price" class="form-label">Price per Night (&#8377;)</label>
                            <input type="number" placeholder="Enter price" class="form-control" name="listing[price]" id="price" required value="<%= listing.price %>">
                            <div class="invalid-feedback">Please enter a valid price.</div>
                        </div>
                        <div class="mb-4 col-md-8">
                            <label for="location" class="form-label">City/Location</label>
                            <input type="text" name="listing[location]" class="form-control" id="location" placeholder="Enter location" required value="<%= listing.location %>">
                            <div class="invalid-feedback">Please specify a location.</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" class="form-control" id="country" placeholder="Enter country" required value="<%= listing.country %>">
                        <div class="invalid-feedback">Please specify a country.</div>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark btn-interact px-4">Cancel</a>
                        <button class="btn btn-success btn-interact px-5">Confirm Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>