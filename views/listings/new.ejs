<% layout("/layouts/boilerplate") %>

<div class="container mt-4 mb-5" data-aos="fade-up">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="ss-form-card">
                <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
                    <div class="text-center mb-4">
                        <h3 class="fw-extrabold mb-1" style="letter-spacing: -0.03em;">List Your Sanctuary</h3>
                        <p class="text-muted">Enter details to share your unique home with global travelers.</p>
                    </div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label for="title" class="form-label">Catchy Title</label>
                        <input type="text" class="form-control" name="listing[title]" id="title"
                            placeholder="e.g. Minimalist Forest Treehouse with Scenic Views" required>
                        <div class="valid-feedback">Title looks great!</div>
                        <div class="invalid-feedback">Please enter a catchy title.</div>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label for="description" class="form-label">Description & Guest Experience</label>
                        <textarea name="listing[description]" id="description" cols="30" rows="6"
                            placeholder="Describe what makes your space special, the surroundings, and key amenities guests will love..." class="form-control" required></textarea>
                        <div class="invalid-feedback">Please enter a description for your listing.</div>
                    </div>

                    <!-- Image Upload -->
                    <div class="mb-4">
                        <label for="image" class="form-label">Cover Image Upload</label>
                        <input type="file" name="listing[image]" id="image" class="form-control" required>
                        <div class="invalid-feedback">Please upload an image for the listing.</div>
                    </div>

                    <!-- Category Radio Select Panel -->
                    <div class="mb-4">
                        <label class="form-label">Listing Category</label>
                        <div class="p-3 bg-light rounded-3 border">
                            <div class="row row-cols-2 row-cols-md-3 g-3">
                                <!-- Rooms -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="rooms" name="listing[category]" value="Rooms" required>
                                        <label class="form-check-label" for="rooms">
                                            <i class="fa-solid fa-bed me-1 text-secondary"></i> Rooms
                                        </label>
                                    </div>
                                </div>
                                <!-- Iconic Cities -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="iconic-cities" name="listing[category]" value="Iconic-Cities" required>
                                        <label class="form-check-label" for="iconic-cities">
                                            <i class="fa-solid fa-mountain-city me-1 text-secondary"></i> Cities
                                        </label>
                                    </div>
                                </div>
                                <!-- Mountains -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="mountains" name="listing[category]" value="Mountains" required>
                                        <label class="form-check-label" for="mountains">
                                            <i class="fa-solid fa-mountain-sun me-1 text-secondary"></i> Mountains
                                        </label>
                                    </div>
                                </div>
                                <!-- Castles -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="castles" name="listing[category]" value="Castles" required>
                                        <label class="form-check-label" for="castles">
                                            <i class="fa-brands fa-fort-awesome me-1 text-secondary"></i> Castles
                                        </label>
                                    </div>
                                </div>
                                <!-- Pools -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="amazing-pools" name="listing[category]" value="Amazing-Pools" required>
                                        <label class="form-check-label" for="amazing-pools">
                                            <i class="fa-solid fa-person-swimming me-1 text-secondary"></i> Pools
                                        </label>
                                    </div>
                                </div>
                                <!-- Cabins -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="cabins" name="listing[category]" value="Cabins" required>
                                        <label class="form-check-label" for="cabins">
                                            <i class="fa-solid fa-house me-1 text-secondary"></i> Cabins
                                        </label>
                                    </div>
                                </div>
                                <!-- Camping -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="camping" name="listing[category]" value="Camping" required>
                                        <label class="form-check-label" for="camping">
                                            <i class="fa-solid fa-campground me-1 text-secondary"></i> Camping
                                        </label>
                                    </div>
                                </div>
                                <!-- Farm -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="farm" name="listing[category]" value="Farm" required>
                                        <label class="form-check-label" for="farm">
                                            <i class="fa-solid fa-cow me-1 text-secondary"></i> Farm
                                        </label>
                                    </div>
                                </div>
                                <!-- Arctic -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="arctic" name="listing[category]" value="Arctic" required>
                                        <label class="form-check-label" for="arctic">
                                            <i class="fa-solid fa-snowflake me-1 text-secondary"></i> Arctic
                                        </label>
                                    </div>
                                </div>
                                <!-- Beach -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="beach" name="listing[category]" value="Beach" required>
                                        <label class="form-check-label" for="beach">
                                            <i class="fa-solid fa-umbrella-beach me-1 text-secondary"></i> Beach
                                        </label>
                                    </div>
                                </div>
                                <!-- Boat -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="boat" name="listing[category]" value="Boat" required>
                                        <label class="form-check-label" for="boat">
                                            <i class="fa-solid fa-sailboat me-1 text-secondary"></i> Boat
                                        </label>
                                    </div>
                                </div>
                                <!-- Ski-in/out -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="ski-in-out" name="listing[category]" value="Ski-in-out" required>
                                        <label class="form-check-label" for="ski-in-out">
                                            <i class="fa-solid fa-person-snowboarding me-1 text-secondary"></i> Ski-in/out
                                        </label>
                                    </div>
                                </div>
                                <!-- Apartment -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="apartment" name="listing[category]" value="Apartment" required>
                                        <label class="form-check-label" for="apartment">
                                            <i class="fa-solid fa-building me-1 text-secondary"></i> Apartment
                                        </label>
                                    </div>
                                </div>
                                <!-- New -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="new" name="listing[category]" value="New" required>
                                        <label class="form-check-label" for="new">
                                            <i class="fa-solid fa-key me-1 text-secondary"></i> New
                                        </label>
                                    </div>
                                </div>
                                <!-- Woodlands -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="woodlands" name="listing[category]" value="Woodlands" required>
                                        <label class="form-check-label" for="woodlands">
                                            <i class="fa-solid fa-tree-city me-1 text-secondary"></i> Woodlands
                                        </label>
                                    </div>
                                </div>
                                <!-- Lake -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="lake" name="listing[category]" value="Lake" required>
                                        <label class="form-check-label" for="lake">
                                            <i class="fa-solid fa-water me-1 text-secondary"></i> Lake
                                        </label>
                                    </div>
                                </div>
                                <!-- Countryside -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="countryside" name="listing[category]" value="Countryside" required>
                                        <label class="form-check-label" for="countryside">
                                            <i class="fa-solid fa-house-chimney-window me-1 text-secondary"></i> Countryside
                                        </label>
                                    </div>
                                </div>
                                <!-- Bed & Breakfast -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="bed-and-breakfasts" name="listing[category]" value="Bed-and-Breakfasts" required>
                                        <label class="form-check-label" for="bed-and-breakfasts">
                                            <i class="fa-solid fa-mug-hot me-1 text-secondary"></i> Bed & Bkfst
                                        </label>
                                    </div>
                                </div>
                                <!-- Campsite -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="campsite" name="listing[category]" value="Campsite" required>
                                        <label class="form-check-label" for="campsite">
                                            <i class="fa-solid fa-tents me-1 text-secondary"></i> Campsite
                                        </label>
                                    </div>
                                </div>
                                <!-- Historical Homes -->
                                <div class="col">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" id="historical-homes" name="listing[category]" value="Historical-Homes" required>
                                        <label class="form-check-label" for="historical-homes">
                                            <i class="fa-solid fa-landmark me-1 text-secondary"></i> Historical
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="invalid-feedback mt-2">Please select a category for your property.</div>
                    </div>

                    <!-- Price, Location, Country Row -->
                    <div class="row g-3">
                        <div class="mb-4 col-md-4">
                            <label for="price" class="form-label">Price per Night (&#8377;)</label>
                            <input type="number" placeholder="1200" class="form-control" name="listing[price]" id="price" required>
                            <div class="invalid-feedback">Please enter a valid nightly price.</div>
                        </div>
                        <div class="mb-4 col-md-8">
                            <label for="location" class="form-label">City/Location</label>
                            <input type="text" name="listing[location]" id="location" class="form-control"
                                placeholder="e.g. Malibu, California" required>
                            <div class="invalid-feedback">Please specify a location.</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" name="listing[country]" id="country" class="form-control"
                            placeholder="e.g. United States" required>
                        <div class="invalid-feedback">Please specify a country.</div>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a href="/listings" class="btn btn-outline-dark btn-interact px-4">Cancel</a>
                        <button class="btn btn-success btn-interact px-5">Publish Listing</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>