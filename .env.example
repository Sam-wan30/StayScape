# StayScape — copy to .env and fill in your values
NODE_ENV=development

# MongoDB connection string (MongoDB Atlas or local)
ATLASDB_URL=mongodb+srv://username:password@cluster.mongodb.net/stayscape

# JWT secret (use a long random string for token signing)
SECRET=your-super-secret-jwt-key-change-this

# Mapbox access token (https://account.mapbox.com/)
MAP_TOKEN=pk.your_mapbox_public_token

# Cloudinary credentials (https://cloudinary.com/)
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# Optional — defaults to 8080
PORT=8080
